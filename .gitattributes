# Normalize line endings — everyone's editor sees LF
* text=auto eol=lf

# Source files always LF
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# Windows-only files keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary types — never normalise
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.pdf   binary
*.pt    binary
*.ckpt  binary
*.safetensors binary
*.zip   binary
*.tar.gz binary

# Lockfiles — keep verbatim, do not diff inline
package-lock.json -diff
