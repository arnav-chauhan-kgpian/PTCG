# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.

# Project root (auto-detected if blank)
PTCG_ROOT=

# Path to the card CSV (auto-detected if blank)
PTCG_CARD_CSV=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (leave blank to disable file logging)
LOG_FILE=logs/ptcg.log
